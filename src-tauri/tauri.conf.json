{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "观测者财务模拟系统",
  "version": "0.2.1",
  "identifier": "com.kanshazhe.financial",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "观测者企业财务模拟系统",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' https://jiaqinw.xyz https://api.web3forms.com https://open.er-api.com; img-src 'self' data:; font-src 'self'; frame-src 'none'; object-src 'none'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": {
      "../docs/系统使用说明书.html": "系统使用说明书.html",
      "../docs/教学知识点介绍.html": "教学知识点介绍.html",
      "../观测者财务_配套资料包/观测者财务_系统介绍.html": "观测者财务_系统介绍.html"
    },
    "windows": {
      "nsis": {
        "languages": ["SimpChinese", "English"],
        "installMode": "currentUser",
        "installerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "updater": {
      "endpoints": ["https://jiaqinw.xyz/updater"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE5Nzc0QTIyOTQ1RDMyQTEKUldTaE1sMlVJa3AzcVViZ0NzU0JlZ1dXalpLL2JTSjB6SUJSeG9EM0tyRHlEN2xzMEdOTGRzQUgK"
    }
  }
}
